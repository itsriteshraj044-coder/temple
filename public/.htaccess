# ----------------------------------------------------------------------------
# Sri Vakrathunda Vinayagar Temple — Apache configuration
#
# This is a single-page app (Vite build). All navigation — including the
# hash routes like #/daily-pooja, #/e-calendar and #/flash/... — is handled
# in the browser by index.html. Any request that is NOT a real file or folder
# is therefore rewritten back to index.html so deep links never 404.
# ----------------------------------------------------------------------------

Options -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # If the site is served from a sub-folder rather than the domain root,
  # uncomment and set this (e.g. "/temple/"):
  # RewriteBase /

  # ---- Force HTTPS (proxy/CDN aware, so it won't loop behind SSL offload) ----
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # ---- SPA fallback: real files/dirs are served as-is, everything else -> app
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  RewriteRule ^ index.html [L]
</IfModule>

# ----------------------------------------------------------------------------
# Compression
# ----------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml \
    text/javascript application/javascript application/json \
    image/svg+xml application/xml
</IfModule>

# ----------------------------------------------------------------------------
# Caching — Vite emits content-hashed assets, so they can live for a year.
# HTML must always revalidate so new deploys are picked up immediately.
# ----------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css              "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp            "access plus 1 year"
  ExpiresByType image/svg+xml         "access plus 1 year"
  ExpiresByType image/gif             "access plus 1 year"
  ExpiresByType font/woff2            "access plus 1 year"
  ExpiresByType audio/mpeg            "access plus 1 year"
  ExpiresByType text/html             "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(js|mjs|css|webp|svg|gif|woff2|ttf|mp3)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# ----------------------------------------------------------------------------
# Correct MIME types (in case the host's defaults are missing any)
# ----------------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType application/javascript js mjs
  AddType image/svg+xml         svg
  AddType image/webp            webp
  AddType font/woff2            woff2
  AddType audio/mpeg            mp3
</IfModule>
